# Default is ARM (Apple Silicon). On an x86_64 / Windows+NVIDIA host you MUST set
# DUCKSOUP_IMAGE=ducksouplab/ducksoup:latest in your local .env, or the x86 Mozza
# plugin (libgstmozza.so) will fail to load.
DUCKSOUP_IMAGE=ducksouplab/ducksoup:arm_latest
DUCKSOUP_ALLOWED_WS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8100,app://bundle
DUCKSOUP_STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun3.l.google.com:19302
DUCKSOUP_TEST_LOGIN=admin
DUCKSOUP_TEST_PASSWORD=admin
DUCKSOUP_LOG_STDOUT=true
DUCKSOUP_LOG_LEVEL=info
# Do NOT set GST_PLUGIN_PATH / LD_LIBRARY_PATH here. The image configures them
# per-architecture and already includes /app/plugins. Hard-coding aarch64 paths
# breaks the x86_64 `ducksouplab/ducksoup:latest` image.
DUCKSOUP_DATA_FOLDER=/app/data
DUCKSOUP_JITTER_BUFFER=120
# Transport-wide congestion control + bandwidth estimation. These are OFF because they crashed the
# SFU mid-session: TWCC rides RTP header extensions, and the container aborted with a GStreamer
# assertion in gst_rtp_base_depayload_handle_buffer (hdrext_buffers non-empty) at ~2m40s, dropping
# the whole call. Leave them false for dyad testing. If you re-enable them, pin a ducksoup image
# where that assertion is fixed and run a full-length dyad first.
DUCKSOUP_GENERATE_TWCC=false
DUCKSOUP_GCC=false
GST_DEBUG=2,videodecoder:1
