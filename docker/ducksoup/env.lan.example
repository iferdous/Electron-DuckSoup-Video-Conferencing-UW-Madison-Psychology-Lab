# Copy this file to docker/ducksoup/.env for a LAN test server.
#
# For the current Electron dev app, both laptops run their own local renderer at
# http://localhost:5173, so localhost:5173 must be allowed even when the DuckSoup
# server itself is hosted on another laptop.
DUCKSOUP_ALLOWED_WS_ORIGINS=http://localhost:5173,http://localhost:8100,http://localhost:3000,http://localhost:4000,http://localhost:8888
DUCKSOUP_STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun3.l.google.com:19302
DUCKSOUP_TEST_LOGIN=admin
DUCKSOUP_TEST_PASSWORD=admin
DUCKSOUP_LOG_STDOUT=true
DUCKSOUP_LOG_LEVEL=info
GST_PLUGIN_PATH=/app/plugins:/usr/lib/aarch64-linux-gnu/gstreamer-1.0
LD_LIBRARY_PATH=/app/plugins:/usr/lib/aarch64-linux-gnu
DUCKSOUP_DATA_FOLDER=/app/data
DUCKSOUP_JITTER_BUFFER=120
GST_DEBUG=2,videodecoder:1
