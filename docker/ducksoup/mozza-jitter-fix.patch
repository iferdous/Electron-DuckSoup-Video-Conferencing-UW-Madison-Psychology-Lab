   /* If gstreamer doesn't provide us with a timestamp, we simply skip the
    * stabilization step */
   if (!GST_BUFFER_PTS_IS_VALID(buf)) {
@@ -282,7 +290,7 @@ gst_mozza_transform_frame_ip (GstOpencvVideoFilter * filter, GstBuffer * buf, cv
