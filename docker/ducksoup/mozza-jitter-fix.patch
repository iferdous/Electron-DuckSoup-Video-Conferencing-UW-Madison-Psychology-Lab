       break;
     case PROP_OE_FC:
       mozza->oe_fc = g_value_get_float(value);
+      if (mozza->oe_filter)
+        mozza->oe_filter->fc = mozza->oe_fc;
       break;
     default:
       G_OBJECT_WARN_INVALID_PROPERTY_ID (object, property_id, pspec);
