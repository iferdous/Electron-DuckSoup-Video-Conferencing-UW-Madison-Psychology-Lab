@@ -269,6 +269,14 @@ gst_mozza_transform_frame_ip (GstOpencvVideoFilter * filter, GstBuffer * buf, cv
 
   std::vector<cv::Point2f> landmarks;
 
+  /* Do not blend a newly acquired face with stale landmarks from before tracking
