   for (size_t i = 0; i < srcGroups.size(); i++)
@@ -347,9 +355,13 @@ gst_mozza_set_property (GObject * object, guint property_id,
       break;
     case PROP_OE_BETA:
       mozza->oe_beta = g_value_get_float(value);
