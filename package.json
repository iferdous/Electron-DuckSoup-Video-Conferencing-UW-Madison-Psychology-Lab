{
  "name": "uw-emotions-lab-conference",
  "version": "0.1.0",
  "description": "Research video conferencing console for live emotion study sessions.",
  "main": "./out/main/index.js",
  "author": "UW-Madison Niedenthal Emotions Lab",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "signal:start": "node server/signaling-server.mjs",
    "signal:dev": "PORT=8765 node server/signaling-server.mjs",
    "media:up": "cd docker/ducksoup && cp -n env.example .env && docker compose up -d",
    "media:down": "cd docker/ducksoup && docker compose down",
    "media:status": "docker ps --format \"table {{.Names}}\\t{{.Status}}\\t{{.Ports}}\"",
    "build:manual": "esbuild ./src/renderer/src/main.tsx --bundle --platform=browser --format=esm --jsx=automatic --outfile=out/renderer/assets/index-manual.js --loader:.css=css --asset-names=assets/[name]-[hash] && esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=out/main/index.js --external:electron --external:@electron-toolkit/utils && esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=out/preload/index.js --external:electron --external:@electron-toolkit/preload",
    "start:manual": "electron .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  }
}
